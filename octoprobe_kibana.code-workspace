{
	"folders": [
		{
			"name": "kibana",
			"path": "."
		},
		{
			"name": "pytest-elasticsearch",
			"path": "../pytest-elasticsearch"
		}
	],
	"settings": {
		"python.testing.pytestEnabled": true,
		"python.testing.pytestArgs": [
			"-v",
			"-s"
		],
		"python.defaultInterpreterPath": "${workspaceFolder:pytest-elasticsearch}/.venv/bin/python",
		"python.analysis.extraPaths": [
			"${workspaceFolder:pytest-elasticsearch}"
		]
	}
}